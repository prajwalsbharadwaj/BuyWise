// BuyWise — Environment Configuration
// This file documents all required environment variables.
// Copy to .env.local and fill in values.

// =============================================================================
// DATABASE
// =============================================================================
// Neon PostgreSQL connection string (with PostGIS)
// Get from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host.neon.tech/buywise?sslmode=require"

// =============================================================================
// AUTHENTICATION (NextAuth.js)
// =============================================================================
// Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

// Google OAuth
// Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

// Email magic links (Resend)
// Get from: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="noreply@buywise.in"

// =============================================================================
// AI / LLM
// =============================================================================
// Google Gemini API (free tier)
// Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

// =============================================================================
// MAPS
// =============================================================================
// Google Maps Platform
// Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=""

// =============================================================================
// STORAGE
// =============================================================================
// Cloudinary (free tier)
// Get from: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

// =============================================================================
// PAYMENTS
// =============================================================================
// Razorpay (test mode initially)
// Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

// =============================================================================
// ANALYTICS
// =============================================================================
// PostHog (free cloud tier)
// Get from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

// =============================================================================
// APP
// =============================================================================
NEXT_PUBLIC_APP_NAME="BuyWise"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
